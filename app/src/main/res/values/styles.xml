<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.IAPTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="CategoryStyle">
        <item name="android:textAppearance">?android:textAppearanceSmall</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:textColorTertiary</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">?android:colorForeground</item>
        <item name="android:padding">5sp</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">25dp</item>
    </style>

    <style name="Category">
        <item name="android:layout">@layout/pref_category</item>
        <item name="android:selectable">false</item>
        <item name="android:shouldDisableView">false</item>
    </style>

    <style name="MyTheme" parent="Theme.MaterialComponents.Light.DarkActionBar.Bridge">
        <item name="android:windowNoTitle">true</item>
        <item name="android:preferenceCategoryStyle">@style/Category</item>
        <item name="android:textColorHint">@color/black_theme_text</item>
        <item name="colorControlNormal">@color/black_theme_tint_color</item>
        <item name="colorControlActivated">@color/black_theme_tint_color</item>
    </style>

    <style name="MyTheme.Black" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/black_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/black_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/black_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.White" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/white_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/white_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/white_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Blue" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/blue_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/blue_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/blue_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Green" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/green_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/green_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/green_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Purple" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/purple_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/purple_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/purple_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Coffee" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/coffee_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/coffee_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/coffee_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Ruby" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/ruby_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/ruby_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/ruby_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="MyTheme.Gray" parent="@style/MyTheme">
        <item name="android:colorForeground">@color/gray_theme_tint_color</item>
        <item name="android:textColorPrimary">@color/gray_theme_field_label_color</item>
        <item name="android:textColorSecondary">@color/gray_theme_text</item>
        <item name="android:textColorTertiary">#ffffff</item>
    </style>

    <style name="KeyboardButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">@drawable/keyboard_button_background</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
    </style>

</resources>
