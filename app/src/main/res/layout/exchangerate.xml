<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/parent_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_theme_background_color">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/keyboardView"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/inner_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Vertical Guideline for Swap Button -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.82" />

            <!-- Row 1: Amount 1 (Foreign by default) -->
            <LinearLayout
                android:id="@+id/foreign_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp"
                app:layout_constraintEnd_toStartOf="@+id/guideline_end"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/lock_foreign"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_lock_open"
                    app:tint="@color/blue_theme_field_label_color" />

                <TextView
                    android:id="@+id/foreign_amount_label"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="4dp"
                    android:text="@string/kLOC_EXCHANGERATE_WORKSHEET_FOREIGNAMOUNT"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/foreign_amount_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:padding="8dp"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/foreign_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="EUR"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/currency_picker_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_drop_down_circle" />
            </LinearLayout>

            <!-- Vertical Link 1 -->
            <View
                android:id="@+id/link1"
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_marginStart="31dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/foreign_row" />

            <TextView
                android:id="@+id/multiply_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="×"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="@id/link1"
                app:layout_constraintStart_toEndOf="@id/link1"
                app:layout_constraintTop_toTopOf="@id/link1" />

            <!-- Row 2: Exchange Rate -->
            <LinearLayout
                android:id="@+id/rate_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp"
                app:layout_constraintEnd_toStartOf="@+id/guideline_end"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/link1">

                <ImageView
                    android:id="@+id/lock_rate"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_lock_open"
                    app:tint="@color/blue_theme_field_label_color" />

                <TextView
                    android:id="@+id/exchange_rate_label"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="4dp"
                    android:text="@string/kLOC_GENERAL_EXCHANGERATE"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/exchange_rate_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="1.0000"
                    android:inputType="numberDecimal"
                    android:padding="8dp"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/fetch_rate_button"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="6dp"
                    android:src="@drawable/ic_globe"
                    app:tint="@color/blue_theme_field_label_color" />
            </LinearLayout>

            <!-- Vertical Link 2 -->
            <View
                android:id="@+id/link2"
                android:layout_width="2dp"
                android:layout_height="24dp"
                android:layout_marginStart="31dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rate_row" />

            <TextView
                android:id="@+id/equals_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="="
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="@id/link2"
                app:layout_constraintStart_toEndOf="@id/link2"
                app:layout_constraintTop_toTopOf="@id/link2" />

            <!-- Row 3: Amount 2 (Account by default) -->
            <LinearLayout
                android:id="@+id/account_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp"
                app:layout_constraintEnd_toStartOf="@+id/guideline_end"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/link2">

                <ImageView
                    android:id="@+id/lock_account"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/blue_theme_field_label_color" />

                <TextView
                    android:id="@+id/account_amount_label"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="4dp"
                    android:text="@string/kLOC_EXCHANGERATE_WORKSHEET_ACCOUNTAMOUNT"
                    android:textSize="10sp" />

                <EditText
                    android:id="@+id/account_amount_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:padding="8dp"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/account_currency_text_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    android:text="GBP"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/account_currency_picker_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_drop_down_circle"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Swap/Invert Section on the right -->
            <View
                android:id="@+id/swap_vertical_line"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:layout_marginStart="0dp"
                app:layout_constraintBottom_toBottomOf="@id/swap_bottom_tick"
                app:layout_constraintStart_toEndOf="@id/swap_top_tick"
                app:layout_constraintTop_toTopOf="@id/swap_top_tick" />

            <View
                android:id="@+id/swap_top_tick"
                android:layout_width="16dp"
                android:layout_height="2dp"
                app:layout_constraintBottom_toBottomOf="@id/foreign_row"
                app:layout_constraintStart_toEndOf="@id/guideline_end"
                app:layout_constraintTop_toTopOf="@id/foreign_row" />

            <View
                android:id="@+id/swap_bottom_tick"
                android:layout_width="16dp"
                android:layout_height="2dp"
                app:layout_constraintBottom_toBottomOf="@id/account_row"
                app:layout_constraintStart_toEndOf="@id/guideline_end"
                app:layout_constraintTop_toTopOf="@id/account_row" />

            <ImageButton
                android:id="@+id/swap_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_swap_vert"
                app:layout_constraintBottom_toBottomOf="@id/swap_vertical_line"
                app:layout_constraintStart_toEndOf="@id/swap_vertical_line"
                app:layout_constraintTop_toTopOf="@id/swap_vertical_line"
                app:tint="@color/blue_theme_field_label_color" />

            <!-- Status/Instructional Indicator -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:padding="16dp"
                android:text="Instructional text will appear here."
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="#888888"
                app:layout_constraintTop_toBottomOf="@id/account_row" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.example.smmoney.views.CurrencyKeyboard
        android:id="@+id/keyboardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
