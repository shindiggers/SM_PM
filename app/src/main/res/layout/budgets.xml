<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Budget Start Date Section -->
        <ImageView
            android:id="@+id/start_date_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_calendar"
            android:paddingTop="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/blue_theme_field_label_color" />

        <TextView
            android:id="@+id/start_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/kLOC_BUDGET_STARTDATE"
            android:paddingTop="6dp"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/start_date_icon"
            app:layout_constraintTop_toTopOf="@id/start_date_icon"
            app:layout_constraintBottom_toBottomOf="@id/start_date_icon"/>

        <TextView
            android:id="@+id/start_date_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:paddingBottom="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/start_date_icon"
            app:layout_constraintEnd_toEndOf="@id/start_date_label"
            app:layout_constraintTop_toBottomOf="@+id/start_date_label"
            tools:text="1 Oct 2026" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/start_date_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="start_date_label,start_date_display" />

        <!-- Period Navigation Section -->
        <ImageView
            android:id="@+id/lefttarrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/content_description_left_arrow"
            android:padding="0dp"
            android:src="@drawable/ic_left_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/periodbutton"
            app:layout_constraintStart_toEndOf="@id/start_date_barrier"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/periodbutton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:letterSpacing="0"
            android:padding="2dp"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/rightarrow"
            app:layout_constraintStart_toEndOf="@+id/lefttarrow"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="1 Oct 2026 - 30 Sep 2027\nYearly" />

        <ImageView
            android:id="@+id/rightarrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@string/content_description_right_arrow"
            android:padding="0dp"
            android:src="@drawable/ic_right_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/the_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/reloadprogressbar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <View
            android:id="@+id/progressbar"
            android:layout_width="0px"
            android:layout_height="0px"
            android:background="@drawable/progressibeam" />

    </FrameLayout>

    <com.example.smmoney.views.BalanceBar
        android:id="@+id/balancebar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:textColor="@color/black_theme_text"
        tools:text="Current balance"
        tools:textColor="@color/black_theme_text" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
