<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_grid"
    android:layout_width="match_parent"
    android:layout_height="260dp"
    android:background="#333333">

    <!-- Row 1 -->
    <Button android:id="@+id/key_1" style="@style/KeyboardButtonStyle" android:text="1"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/key_2" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_2" style="@style/KeyboardButtonStyle" android:text="2"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@id/key_1" app:layout_constraintEnd_toStartOf="@id/key_3" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_3" style="@style/KeyboardButtonStyle" android:text="3"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@id/key_2" app:layout_constraintEnd_toStartOf="@id/key_delete" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <ImageButton android:id="@+id/key_delete" style="@style/KeyboardButtonStyle" android:src="@drawable/ic_backspace_24dp" android:contentDescription="delete"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@id/key_3" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />

    <!-- Row 2 -->
    <Button android:id="@+id/key_4" style="@style/KeyboardButtonStyle" android:text="4"
        app:layout_constraintTop_toBottomOf="@id/key_1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/key_5" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_5" style="@style/KeyboardButtonStyle" android:text="5"
        app:layout_constraintTop_toBottomOf="@id/key_2" app:layout_constraintStart_toEndOf="@id/key_4" app:layout_constraintEnd_toStartOf="@id/key_6" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_6" style="@style/KeyboardButtonStyle" android:text="6"
        app:layout_constraintTop_toBottomOf="@id/key_3" app:layout_constraintStart_toEndOf="@id/key_5" app:layout_constraintEnd_toStartOf="@id/key_minus" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_minus" style="@style/KeyboardButtonStyle" android:text="-"
        app:layout_constraintTop_toBottomOf="@id/key_delete" app:layout_constraintStart_toEndOf="@id/key_6" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />

    <!-- Row 3 -->
    <Button android:id="@+id/key_7" style="@style/KeyboardButtonStyle" android:text="7"
        app:layout_constraintTop_toBottomOf="@id/key_4" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/key_8" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_8" style="@style/KeyboardButtonStyle" android:text="8"
        app:layout_constraintTop_toBottomOf="@id/key_5" app:layout_constraintStart_toEndOf="@id/key_7" app:layout_constraintEnd_toStartOf="@id/key_9" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_9" style="@style/KeyboardButtonStyle" android:text="9"
        app:layout_constraintTop_toBottomOf="@id/key_6" app:layout_constraintStart_toEndOf="@id/key_8" app:layout_constraintEnd_toStartOf="@id/key_clear" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_clear" style="@style/KeyboardButtonStyle" android:text="C"
        app:layout_constraintTop_toBottomOf="@id/key_minus" app:layout_constraintStart_toEndOf="@id/key_9" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />

    <!-- Row 4 -->
    <ImageButton android:id="@+id/key_hide" style="@style/KeyboardButtonStyle" android:src="@drawable/ic_keyboard_hide_24dp" android:contentDescription="hide"
        app:layout_constraintTop_toBottomOf="@id/key_7" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/key_0" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_0" style="@style/KeyboardButtonStyle" android:text="0"
        app:layout_constraintTop_toBottomOf="@id/key_8" app:layout_constraintStart_toEndOf="@id/key_hide" app:layout_constraintEnd_toStartOf="@id/key_dot" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_dot" style="@style/KeyboardButtonStyle" android:text="."
        app:layout_constraintTop_toBottomOf="@id/key_9" app:layout_constraintStart_toEndOf="@id/key_0" app:layout_constraintEnd_toStartOf="@id/key_next" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />
    <Button android:id="@+id/key_next" style="@style/KeyboardButtonStyle" android:text="@string/kLOC_GENERAL_NEXT"
        app:layout_constraintTop_toBottomOf="@id/key_clear" app:layout_constraintStart_toEndOf="@id/key_dot" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHeight_percent="0.25" app:layout_constraintWidth_percent="0.25" />

</androidx.constraintlayout.widget.ConstraintLayout>
